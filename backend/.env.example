# ===== LLM（gpt-5.5 多模态，httpx 直连；勿用 openai SDK，会被 Cloudflare WAF 拦）=====
GPT_API_KEY=
GPT_BASE_URL=https://gpt.pkpp.cn/v1
GPT_MODEL=gpt-5.5
GPT_REASONING=high
# 视觉定位/抽取用低推理（省时，G0 实测坐标质量无损）
VLM_REASONING=low
LLM_TIMEOUT_SEC=120
VLM_DAILY_BUDGET=2000

# ===== 端点安全（主防线，见 plan AC12）=====
# BIND_HOST=127.0.0.1 时仅本机可访问；改为 0.0.0.0 远程访问时必须设置高熵 TERMINAL_TOKEN
BIND_HOST=127.0.0.1
TERMINAL_TOKEN=

# ===== 数据库 =====
DATABASE_URL=sqlite:///./data/boss_autoapply.db

# ===== 限速 / 配额（仅作 RulesConfig 首次缺省填充；运行期以 DB Config.rules 为权威）=====
DAILY_APPLY_LIMIT=150
APPLY_INTERVAL_MIN=20
APPLY_INTERVAL_MAX=90

# ===== 巡检 =====
INBOX_POLL_MIN_SEC=120
INBOX_POLL_MAX_SEC=300
SCORE_THRESHOLD=80
